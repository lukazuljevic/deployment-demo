generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")  
}

enum ClothingSize{
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum ProductType{
  CLOTHING
  SHOES
}

enum Role{
  USER
  ADMIN
}

enum OrderStatus{
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
}

enum AddressType{
  BILLING
  SHIPPING
}

enum ProductColor {
  BLACK
  WHITE
  GRAY
  BLUE
  GREEN
  RED
  YELLOW
  LEATHER
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String 
  firstName String
  lastName String
  addresses Address[]
  card UserCard?
  role Role @default(USER)
  orders Order[]
  favorites Favorite[]
  notifications Notification[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model Notification{
  id String @id @default(uuid())
  userId String
  message String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId],references: [id], onDelete: Cascade)
}

model UserCard{
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId],references:[id])
  expiryMonth Int
  expiryYear Int
  iban String
  cvc String
}

model Address{
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId],references:[id])
  type AddressType
  street String
  city String
  country String
  county String
  zipcode String

  billingOrders Order[] @relation("BillingOrder")
  shippingOrders Order[] @relation("ShippingOrder")
}

model Product{
  id String @id @default(uuid())
  name String
  description String
  brand String
  price Decimal @db.Decimal(10,2)

  categoryId String
  category Category @relation(fields: [categoryId],references: [id])

  type ProductType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  

  variants ProductVariant[]
  images ProductImage[]
  favorites Favorite[]
}

model ProductVariant{
  id String @id @default(uuid())
  productId String
  product Product @relation(fields: [productId],references: [id], onDelete: Cascade)
  clothingSize ClothingSize?
  shoeSize Int?
  stock Int @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
  orderItems OrderItem[]
  cartItems CartItem[]
}

model ProductImage{
  id String @id @default(uuid())
  productId String
  url String
  color ProductColor?
  product Product @relation(fields: [productId],references: [id],onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model Category{
  id String @id @default(uuid())
  name String
  products Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt    
}

model Favorite{
  id String @id @default(uuid())  
  userId String
  productId String

  user User @relation(fields: [userId],references:[id])
  product Product @relation(fields: [productId],references:[id])
  createdAt DateTime @default(now())

  @@unique([userId,productId])
}

model Cart{
  id String @id @default(uuid())
  userId String @unique
  items CartItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model CartItem{
  id String @id @default(uuid())
  cartId String
  variantId String
  color ProductColor
  quantity Int
  cart Cart @relation(fields: [cartId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model Order{
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId],references:[id])
  totalPrice Decimal @db.Decimal(10,2)
  status OrderStatus @default(PENDING)
  billingAddressId  String
  shippingAddressId String

  billingAddress Address @relation("BillingOrder", fields: [billingAddressId], references: [id])
  shippingAddress Address @relation("ShippingOrder", fields: [shippingAddressId], references: [id])

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt      
}

model OrderItem{
  id String @id @default(uuid())

  orderId String
  order Order @relation(fields: [orderId],references: [id])

  variantId String
  productVariant ProductVariant @relation(fields: [variantId],references:[id])

  quantity Int
  price Decimal @db.Decimal(10,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt      
}


