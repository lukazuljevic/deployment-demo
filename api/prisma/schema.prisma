generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ShirtSize{
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum ProductType{
  CLOTHING
  SHOES
}

enum Role{
  USER
  ADMIN
}

enum OrderStatus{
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String 
  firstName String
  lastName String
  avatarUrl String?
  address Address?
  card UserCard?
  role Role @default(USER)
  orders Order[]
  favorites Favorite[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model UserCard{
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId],references:[id])

  expiryMonth Int
  expiryYear Int
  iban String
  cvc String
}

model Address{
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId],references:[id])

  street String
  city String
  country String
  zipcode String
}

model Product{
  id String @id @default(uuid())
  name String
  description String
  brand String
  price Decimal @db.Decimal(10,2)

  categoryId String
  category Category @relation(fields: [categoryId],references: [id])

  type ProductType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  

  variants ProductVariant[]
  images ProductImage[]
  favorites Favorite[]
  orderItems OrderItem[]
}

model ProductVariant{
  id String @id @default(uuid())
  productId String
  product Product @relation(fields: [productId],references: [id])
  shirtSize ShirtSize?
  shoeSize Int?
  stock Int @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model ProductImage{
  id String @id @default(uuid())
  productId String
  url String
  color String?
  product Product @relation(fields: [productId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model Category{
  id String @id @default(uuid())
  name String
  products Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt    
}

model Favorite{
  id String @id @default(uuid())  
  userId String
  productId String

  user User @relation(fields: [userId],references:[id])
  product Product @relation(fields: [productId],references:[id])
  createdAt DateTime @default(now())

  @@unique([userId,productId])
}

model Order{
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId],references:[id])

  totalPrice Decimal @db.Decimal(10,2)

  shippingStreet  String
  shippingCity    String
  shippingCountry String
  shippingZipcode String

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt      
}

model OrderItem{
  id String @id @default(uuid())

  orderId String
  order Order @relation(fields: [orderId],references: [id])

  productId String
  product Product @relation(fields: [productId],references:[id])

  status OrderStatus
  quantity Int
  price Decimal @db.Decimal(10,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt      
}
